# 富途 OpenD 環境變量
# ========================

# OpenD 主機地址 (本地用 127.0.0.1，VPS remote 用實際 IP)
FUTU_HOST=127.0.0.1
FUTU_PORT=11111

# 富途登入 (VPS remote OpenD 需要)
FUTU_LOGIN_ACCOUNT=你的牛牛ID
FUTU_LOGIN_PWD_MD5=密碼MD5

# 交易密碼 (解鎖交易功能)
FUTU_TRADE_PWD=

# Python Backend API
PYTHON_API_URL=http://localhost:8000

# 訪問 App 密碼
APP_PASSWORD=

# =============================================================================
# 調試選項
# =============================================================================
# 停用 futu-api 日誌寫入（避免沙盒環境 / 權限問題）
FUTU_DISABLE_LOG=1
