# 富途 API 環境變量
# ========================
# 重要：密碼必須係 32位元小寫 MD5 格式！
# 可以用呢個網站生成 MD5: https://www.md5hashgenerator.com/

# 富途帳戶 (email 或者用戶 ID)
FUTU_LOGIN_ACCOUNT=your_email@example.com

# 富途登入密碼既 MD5 (32位元小寫)
# 例如密碼係 "abc123", MD5 係 "e99a18c428cb38d5f260853678922e03
FUTU_LOGIN_PWD_MD5=your_md5_password_here

# 富途網關連線 (一般唔洗改)
FUTU_HOST=futuopend
FUTU_PORT=11111
