# 富途 OpenD 環境變量
# ========================

# OpenD API 端口 (11111 = 交易/行情接口)
FUTU_HOST=host.docker.internal
FUTU_PORT=11111

# 交易密碼 (解鎖交易功能)
FUTU_TRADE_PWD=

# Python Backend API
PYTHON_API_URL=http://localhost:8000

# =============================================================================
# 調試選項
# =============================================================================
# 停用 futu-api 日誌寫入（避免沙盒環境 / 權限問題）
# 喺 Cursor IDE 沙盒或遇到 log 權限問題時設置為 1
FUTU_DISABLE_LOG=1

# 訪問 App 嘅密碼
APP_PASSWORD=
