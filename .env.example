# 富途 API 環境變量（用於 /api/futu 報價同 K 線）
# ========================
# 重要：必須啟用 OpenD 既 WebSocket 功能！
# 係 FutuOpenD.xml 度設定 <websocket_port>33333</websocket_port>

# OpenD WebSocket 連接（本機預設即可）
# 重要：呢個係 WebSocket port，唔係 API port！
FUTU_HOST=127.0.0.1
FUTU_WS_PORT=11112

# OpenD API port（目前主要用 WebSocket，这个可能不需要）
FUTU_PORT=11111

# OpenD 登入帳戶（如果 OpenD 有設定登入密碼）
# 可以填 email、手機號碼或用戶 ID
FUTU_LOGIN_ACCOUNT=kelly0050@gmail.com

# 登入密碼既 MD5（32 位小寫）- 如果 OpenD 有設定密碼
# FUTU_LOGIN_PWD_MD5=your_md5_password_here

# Python Backend API（富途持倉同步）
# ========================
# 如果使用 Python backend，呢個係 Next.js 連接既 URL
PYTHON_API_URL=http://localhost:8000

# Python backend 既環境變量（直接俾 Python 用）
# 如果 Python 同 Next.js 同一機器，可以用上面既 FUTU_HOST/PORT
FUTU_TRADE_PWD=
