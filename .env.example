# 富途 API 環境變量（用於 /api/futu 報價同 K 線）
# ========================
# 重要：密碼必須係 32 位小寫 MD5！可到 https://www.md5hashgenerator.com/ 生成

# 富途牛牛「用戶 ID」數字（喺 OpenD 介面可見到，例如 7202895）
FUTU_USER_ID=7202895

# 富途登入密碼既 MD5（32 位小寫）
FUTU_LOGIN_PWD_MD5=your_md5_password_here

# 可選：若用 FUTU_LOGIN_ACCOUNT 代替 FUTU_USER_ID，必須填數字 ID
# FUTU_LOGIN_ACCOUNT=7202895

# OpenD 連線（本機預設即可）
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
