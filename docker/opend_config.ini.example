# =============================================================================
# Futu OpenD 配置文件範本 (opend_config.ini.example)
# =============================================================================
# 複製呢個 file 去做 docker/opend_config.ini
# cp docker/opend_config.ini.example docker/opend_config.ini
# 然後填入你既富途 credentials
#
# ⚠️ 重要：docker/opend_config.ini 已加入 .gitignore，唔會被 push 上 GitHub！
# =============================================================================

[login]
# 富途登入帳號 (用戶ID / 電話 / Email)
login_account = 你的富途用戶ID

# 富途登入密碼的 MD5 (32位小寫)
# 計算方法：echo -n "你的密碼" | md5sum
# 或者用網站：https://www.md5online.org/md5-encrypt.html
login_pwd_md5 = 你的密碼MD5

[server]
# 必須設為 0.0.0.0，等 Docker 網絡可以訪問
ip = 0.0.0.0

# API 端口 (供 Backend 連接)
port = 11111

# WebSocket 端口
websocket_port = 8081

[trade]
# 加密類型：0 = 不加密 (使用 login_account + login_pwd_md5)
encrypt_type = 0

# 交易環境：SIMULATE 或 REAL
# 建議先用 SIMULATE 測試
trd_env = SIMULATE

[log]
# 日誌級別
log_level = INFO

# 日誌目錄
log_path = ./logs
