# =============================================================================
# Nginx 配置模板 - VCP Position Calculator
# =============================================================================
# 功能：
#   - HTTPS (Let's Encrypt)
#   - Basic Auth 密碼保護
#   - Reverse Proxy 到 Frontend + Backend
#
# 使用方法：
#   1. 將此檔案複製到 /etc/nginx/sites-available/vcp-calculator
#   2. 修改 server_name 為你的域名
#   3. 修改 auth_basic_user_file 指向正確的密碼檔位置
#   4. ln -s /etc/nginx/sites-available/vcp-calculator /etc/nginx/sites-enabled/
#   5. nginx -t && systemctl reload nginx
#   6. certbot --nginx -d your-domain.com  # 申請 SSL 證書
# =============================================================================

# HTTP -> HTTPS 強制跳轉
server {
    listen 80;
    server_name your-domain.com;  # 修改為你的域名

    # Let's Encrypt 驗證
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    # 強制跳轉到 HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS 主站點
server {
    listen 443 ssl;
    server_name your-domain.com;  # 修改為你的域名

    # -------------------------------------------------------------------------
    # SSL 配置 (Let's Encrypt 會自動更新這些)
    # -------------------------------------------------------------------------
    ssl_certificate /etc/letsencrypt/live/your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # -------------------------------------------------------------------------
    # 安全 Headers
    # -------------------------------------------------------------------------
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # -------------------------------------------------------------------------
    # 密碼認證 (強烈建議開啟！)
    # -------------------------------------------------------------------------
    # 創建密碼檔：
    #   apt install apache2-utils
    #   htpasswd -c /etc/nginx/.htpasswd admin
    auth_basic "VCP Position Calculator - Login Required";
    auth_basic_user_file /etc/nginx/.htpasswd;

    # -------------------------------------------------------------------------
    # 日誌
    # -------------------------------------------------------------------------
    access_log /var/log/nginx/vcp-access.log;
    error_log /var/log/nginx/vcp-error.log;

    # -------------------------------------------------------------------------
    # Frontend (Next.js)
    # -------------------------------------------------------------------------
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 300s;
        proxy_connect_timeout 75s;
    }

    # -------------------------------------------------------------------------
    # Backend API (FastAPI)
    # -------------------------------------------------------------------------
    location /api/ {
        proxy_pass http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 10M;
    }

    # -------------------------------------------------------------------------
    # 允許 Let's Encrypt 自動更新
    # -------------------------------------------------------------------------
    location /.well-known/acme-challenge/ {
        auth_basic off;
        root /var/www/html;
    }
}
